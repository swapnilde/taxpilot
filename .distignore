# This is the list of files and directories to EXCLUDE
# from plugin distribution ZIPs (wp.org, GitHub releases).

# Source / dev files
.editorconfig
.eslintrc.js
.gitignore
.phpcs.xml.dist
.stylelintrc.json
.distignore
.git/
.gitkeep

# Dev dependencies & tooling
node_modules/
vendor/
package.json
package-lock.json
webpack.config.js

# Source files (built assets are in build/)
src/

# Scripts
scripts/

# Tests
tests/
phpunit.xml
phpunit.xml.dist
.phpunit.result.cache
coverage/

# GitHub & WordPress Meta
.github/
.wordpress-org/
CONTRIBUTING.md
CHANGELOG.md
DEVELOPER.md

# Misc
.DS_Store
Thumbs.db
*.log
*.zip
